# ============================================================
# RICMS Environment Variables
# Copy this file to .env and fill in production values.
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=ricms_secret

# JWT signing secret (must be at least 256 bits / 32+ characters)
JWT_SECRET=a-very-long-secret-key-for-ricms-that-is-at-least-256-bits-long-and-secure

# AES-256-GCM key for encrypting sensitive fields at rest.
# MUST be a valid Base64-encoded 32-byte key (256 bits).
# Generate a new one with: openssl rand -base64 32
# The default below is safe for local development only — replace in production.
APP_ENCRYPTION_SECRET_KEY=WnVea3WTlDC0CXcZaL/SDRVSisv4xPnyM1Ja8VFoGWo=
